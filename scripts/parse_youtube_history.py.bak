#!/usr/bin/env python3
"""Parse YouTube watch history and extract video IDs."""

import argparse
import json
import logging
import re
import subprocess
from pathlib import Path

import requests
import yt_dlp

logging.basicConfig(level=logging.INFO, format="%(name)s %(levelname)s: %(message)s")
logger = logging.getLogger(__name__)

_YOUTUBE_VIDEO_ID = re.compile(r"(?:youtube\.com/watch\?.*v=)([\w-]{11})")
_YOUTUBE_SHORT = re.compile(r"(?:youtu\.be/)([\w-]{11})")


def parse_cookies(path: str) -> dict:
    """Parse Netscape cookies file into dict."""
    cookies = {}
    if not Path(path).exists():
        return cookies

    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            parts = line.split("\t")
            if len(parts) >= 7:
                cookies[parts[5]] = parts[6]  # name -> value

    logger.debug("Parsed %d cookies", len(cookies))
    return cookies


def fetch_history(url: str, browser: str, proxy: str | None) -> str:
    """Fetch history page and return content."""
    cookie_file = "/tmp/yt_cookies.txt"

    # Export cookies via yt-dlp
    try:
        subprocess.run(
            [
                "yt-dlp",
                "--cookies-from-browser",
                browser,
                "--cookies",
                cookie_file,
                "https://www.youtube.com",
            ],
            capture_output=True,
            timeout=60,
        )
    except Exception as e:
        logger.warning("Cookie export failed: %s", e)

    proxies = {"http": proxy, "https": proxy} if proxy else None
    headers = {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"}

    # Try requests with cookies dict
    try:
        cookie_dict = parse_cookies(cookie_file)
        resp = requests.get(
            "https://www.youtube.com/history",
            headers=headers,
            cookies=cookie_dict,
            proxies=proxies,
            timeout=30,
        )
        logger.info("Fetched history: %d bytes", len(resp.text))
        if "videoId" in resp.text:
            return resp.text
    except Exception as e:
        logger.warning("Method 1 failed: %s", e)

    # Try yt-dlp
    try:
        ydl_opts = {
            "quiet": True,
            "no_warnings": True,
            "skip_download": True,
            "flatplaylist": True,
            "extract_flat": True,
        }
        if Path(cookie_file).exists():
            ydl_opts["cookiefile"] = cookie_file
        if proxy:
            ydl_opts["proxy"] = proxy

        with yt_dlp.YoutubeDL(ydl_opts) as ydl:
            info = ydl.extract_info("https://www.youtube.com/feed/history", download=False)
            if info and info.get("entries"):
                ids = [e["id"] for e in info["entries"] if e.get("id")]
                if ids:
                    logger.info("Found %d IDs via yt-dlp", len(ids))
                    return json.dumps({"video_ids": ids})
    except Exception as e:
        logger.warning("Method 2 failed: %s", e)

    # Fallback to raw HTML
    try:
        cookie_dict = parse_cookies(cookie_file)
        resp = requests.get(url, headers=headers, cookies=cookie_dict, proxies=proxies, timeout=30)
        return resp.text if resp.status_code == 200 else ""
    except Exception as e:
        logger.warning("Method 3 failed: %s", e)
        return ""


def extract_ids(text: str) -> list[str]:
    """Extract video IDs from text."""
    ids = set()

    for p in [_YOUTUBE_VIDEO_ID, _YOUTUBE_SHORT]:
        for m in p.finditer(text):
            if len(m.group(1)) == 11:
                ids.add(m.group(1))

    for m in re.finditer(r'"videoId":"([\w-]{11})"', text):
        ids.add(m.group(1))

    return sorted(ids)


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--url", default="https://www.youtube.com/feed/history")
    parser.add_argument("--browser", default="chrome")
    parser.add_argument("--proxy")
    parser.add_argument("-o", "--output")
    parser.add_argument("-v", "--verbose", action="store_true")
    args = parser.parse_args()

    if args.verbose:
        logging.getLogger().setLevel(logging.DEBUG)

    html = fetch_history(args.url, args.browser, args.proxy)
    if not html:
        logger.error("Failed to fetch history")
        return

    ids = extract_ids(html)
    logger.info("Found %d video IDs", len(ids))

    for vid in ids:
        print(f"https://www.youtube.com/watch?v={vid}")

    if args.output:
        Path(args.output).write_text(json.dumps(ids, indent=2))
        logger.info("Saved to: %s", args.output)


if __name__ == "__main__":
    main()
